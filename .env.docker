
# .env.docker (для docker-compose и локального docker-запуска)
DB_HOST=postgresql
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=request-system

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=request-system

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-before-shared-use
